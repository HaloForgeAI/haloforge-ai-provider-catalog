{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://haloforge.dev/schema/model-provider-catalog.schema.json",
  "title": "HaloForge AI model provider catalog",
  "type": "object",
  "required": ["schemaVersion", "updatedAt", "source", "repository", "providers"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "updatedAt": { "type": "string" },
    "source": { "type": "string" },
    "repository": { "type": "string" },
    "upstreamSources": {
      "type": "array",
      "items": { "$ref": "#/$defs/upstreamSource" }
    },
    "providers": {
      "type": "array",
      "items": { "$ref": "#/$defs/provider" }
    }
  },
  "$defs": {
    "upstreamSource": {
      "type": "object",
      "required": ["id", "name", "url"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "kind": {
          "enum": ["official", "aggregator", "open_source", "community"]
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "provider": {
      "type": "object",
      "required": [
        "id",
        "name",
        "category",
        "iconProvider",
        "apiCompatibility",
        "authType",
        "models",
        "agentGateways"
      ],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "iconProvider": { "type": "string" },
        "modelOwner": { "type": "string" },
        "modelOwnerLabel": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "apiKeyUrl": { "type": "string" },
        "baseUrl": { "type": "string" },
        "apiCompatibility": { "type": "string" },
        "authType": {
          "enum": ["bearer", "api-key", "header-api-key", "x-goog-api-key"]
        },
        "modelsListPath": { "type": "string" },
        "extraHeaders": { "type": "object" },
        "models": {
          "type": "array",
          "items": { "$ref": "#/$defs/model" }
        },
        "agentGateways": {
          "type": "array",
          "items": { "$ref": "#/$defs/agentGateway" }
        }
      },
      "additionalProperties": true
    },
    "model": {
      "type": "object",
      "required": ["id", "displayName"],
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "contextWindow": { "type": "integer" },
        "maxTokens": { "type": "integer" },
        "status": { "$ref": "#/$defs/lifecycleStatus" },
        "deprecationDate": { "type": "string" },
        "shutdownDate": { "type": "string" },
        "fallbackModelId": { "type": "string" },
        "disabledByDefault": { "type": "boolean" },
        "source": { "type": "string" }
      },
      "additionalProperties": true
    },
    "agentGateway": {
      "type": "object",
      "required": ["target", "routeMode"],
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "description": { "type": "string" },
        "target": {
          "enum": ["claude_code", "codex", "opencode", "copilot", "qwen_code"]
        },
        "routeMode": {
          "enum": ["direct", "model_mapping", "config_only"]
        },
        "baseUrl": { "type": "string" },
        "apiCompatibility": { "type": "string" },
        "modelId": { "type": "string" },
        "contextWindow": { "type": "integer" },
        "maxTokens": { "type": "integer" },
        "temperature": { "type": "number" },
        "effortLevel": { "type": "string" },
        "roleModels": { "type": "object" },
        "generationConfig": { "type": "object" },
        "status": { "$ref": "#/$defs/lifecycleStatus" },
        "deprecationDate": { "type": "string" },
        "shutdownDate": { "type": "string" },
        "fallbackModelId": { "type": "string" },
        "disabledByDefault": { "type": "boolean" },
        "source": { "type": "string" }
      },
      "additionalProperties": true
    },
    "lifecycleStatus": {
      "enum": [
        "available",
        "preview",
        "experimental",
        "deprecated",
        "shutdown",
        "restricted",
        "disabled"
      ]
    }
  }
}
